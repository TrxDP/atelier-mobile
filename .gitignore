# ─────────────────────────────────────────
#  ATELIER – Root .gitignore (monorepo)
# ─────────────────────────────────────────

# ── Dependencias ──────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ── Logs ──────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-debug.log*
lerna-debug.log*

# ── Variables de entorno / Secretos ───────
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.p8

# ── TypeScript / Compilación ───────────────
dist/
build/
lib/
out/
*.tsbuildinfo

# ── Test / Cobertura ──────────────────────
coverage/
.nyc_output/

# ── Expo / React Native ───────────────────
.expo/
web-build/
expo-env.d.ts
.metro-health-check*

# Archivos de firma / certificados
*.jks
*.keystore
*.apk
*.aab
*.ipa
*.mobileprovision

# Carpetas nativas generadas (Expo bare workflow)
mobile/ios/
mobile/android/
mobile/.kotlin/
*.orig.*

# ── WatermelonDB / SQLite ─────────────────
*.db
*.db-journal
*.sqlite
*.sqlite-journal

# ── Docker ────────────────────────────────
docker-compose.override.yml

# ── Sistema operativo ─────────────────────
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ── Editores / IDEs ───────────────────────
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.bak
